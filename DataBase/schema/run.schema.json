{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentharness.local/schema/run.schema.json",
  "title": "Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "agent_id",
    "status",
    "started_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^run_[a-zA-Z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[a-zA-Z0-9_-]+$"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "blocked",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
