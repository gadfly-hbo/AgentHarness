{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentharness.local/schema/memory-candidate.schema.json",
  "title": "MemoryCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_run_id",
    "scope",
    "content",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^memcand_[a-zA-Z0-9_-]+$"
    },
    "source_run_id": {
      "type": "string",
      "pattern": "^run_[a-zA-Z0-9_-]+$"
    },
    "source_artifact_id": {
      "type": "string",
      "pattern": "^artifact_[a-zA-Z0-9_-]+$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string"
    }
  }
}
